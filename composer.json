{
  "name": "anemoiaa/ah-test-assignment",
  "autoload": {
    "psr-4": {
      "Anemoiaa\\AhTestAssignment\\": "app/"
    }
  },
  "authors": [
    {
      "name": "Anemoiaa",
      "email": "georgiypetroff@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-pdo": "*",
    "smarty/smarty": "^5.7",
    "vlucas/phpdotenv": "^5.6",
    "fakerphp/faker": "^1.24"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8"
  },
  "scripts": {
    "post-install-cmd": [
      "@composer bin php-cs-fixer install --ansi"
    ],

    "code-style-fix": "php-cs-fixer --ansi fix -v --diff",
    "code-style-check": "@code-style-fix --dry-run",
    "code-style-describe": "php-cs-fixer --ansi describe"
  },
  "config": {
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  }
}
